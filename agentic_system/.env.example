# PipFlow AI - Environment Variables Example
# Copy to .env and fill in real values.  NEVER commit .env.

# ── LLM Provider selection ────────────────────────────────────
# Set this to switch providers.  Only the matching API key is needed.
# Available: deepseek | openai | anthropic | gemini | kimi | grok
LLM_PROVIDER=deepseek

# ── DeepSeek (default) ───────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat          # deepseek-chat | deepseek-reasoner

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini              # gpt-4o | gpt-4o-mini | gpt-4-turbo | o1 | o3-mini

# ── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514  # claude-opus-4-20250514 | claude-haiku-3-5

# ── Google Gemini ────────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash         # gemini-2.5-pro-preview | gemini-1.5-flash

# ── Kimi (Moonshot AI) ───────────────────────────────────────
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k             # moonshot-v1-32k | moonshot-v1-128k

# ── Grok (xAI) ───────────────────────────────────────────────
XAI_API_KEY=
GROK_MODEL=grok-2-latest              # grok-2 | grok-3-mini

# ── MT5 Bridge ────────────────────────────────────────────────
MT5_BRIDGE_URL=http://localhost:8888
MT5_BRIDGE_API_KEY=                    # required for live trading
MT5_BRIDGE_TIMEOUT=30.0

# ── API Server ────────────────────────────────────────────────
PIPFLOW_API_KEY=                       # required — no default
CORS_ORIGIN=http://localhost:3000      # comma-separated origins
RATE_LIMIT=60/minute

# ── News / Sentiment ─────────────────────────────────────────
NEWS_API_KEY=
ALPHA_VANTAGE_KEY=

# ── Alerting ──────────────────────────────────────────────────
ALERT_WEBHOOK_URL=                     # Slack / Discord / generic webhook

# ── Redis (optional, for caching / health check) ─────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage paths (override defaults) ─────────────────────────
# STORAGE_ROOT=./storage
